# Drivio Selfdrive Cars - Environment Variables Template
# Copy this file to '.env.local' and replace the values with your actual configuration.

# Google Sheets Apps Script Web App URL for Contact Form Submissions
# This is loaded SECURELY on the server-side, hiding your webhook URL from the browser network tab.
# Follow instructions in 'GoogleSheetsScript.txt' to generate this URL.
SHEET_WEBHOOK_URL=https://script.google.com/macros/s/your-unique-script-id-here/exec
